# ZASS — Environment variables
# Copy this file to ".env" and fill in real values.
# NEVER commit the real ".env" file — it is git-ignored.

# Runtime environment. One of: development | production | test
# Controls logger format/level and the value returned by GET /health.
NODE_ENV=development

# Port the HTTP server listens on.
PORT=8000

# Neon POOLED connection string — used by the running app (PrismaClient).
# This is the connection that goes through Neon's PgBouncer pooler.
DATABASE_URL="postgresql://user:password@host-pooler.region.aws.neon.tech/dbname?sslmode=require"

# Neon DIRECT connection string — used ONLY by Prisma migrations.
# Bypasses the pooler (migrations need a direct, non-pooled connection).
DIRECT_URL="postgresql://user:password@host.region.aws.neon.tech/dbname?sslmode=require"

# Secret used to sign/verify short-lived ACCESS tokens.
# Use a long, random string (e.g. `openssl rand -base64 48`).
JWT_SECRET="replace-with-a-long-random-access-token-secret"

# Secret used to sign/verify long-lived REFRESH tokens.
# Must be DIFFERENT from JWT_SECRET. Also long and random.
JWT_REFRESH_SECRET="replace-with-a-long-random-refresh-token-secret"

# Lifetime of an access token (Flutter re-authenticates after this).
# Accepts vercel/ms style durations, e.g. 15m, 1h.
JWT_ACCESS_EXPIRES_IN=15m

# Lifetime of a refresh token (stored in the Token table in the DB).
# Accepts vercel/ms style durations, e.g. 30d, 7d.
JWT_REFRESH_EXPIRES_IN=7d

# Allowed CORS origin(s) for the API.
# Use "*" to allow any origin, or a comma-separated list of origins.
CORS_ORIGIN=*

# Base URL of the frontend password-reset screen.
# The reset email links to "${APP_RESET_URL}?token=...".
APP_RESET_URL=http://localhost:8080/reset-password

# --- Email (nodemailer SMTP) ---
# Leave SMTP_HOST empty to disable real sending: the app then uses the
# log-only email provider (welcome/reset emails are logged, not sent).
SMTP_HOST=
# Common ports: 587 (STARTTLS) or 465 (implicit TLS).
SMTP_PORT=587
# "true" ONLY for port 465; "false" for 587.
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# From header on outgoing emails.
EMAIL_FROM="ZASS <no-reply@zass.local>"

# --- WhatsApp (whatsapp-web.js) ---
# false (default) -> message provider uses the log-only stub; no Chromium /
# WhatsApp session is launched. Set true to send real WhatsApp messages.
# Requires a persistent SINGLE instance (never serverless / multi-instance).
WHATSAPP_ENABLED=false
# Folder where the WhatsApp session is persisted (must be durable disk).
# First run prints/serves a QR — scan it once from the linked phone.
WHATSAPP_SESSION_PATH=.wwebjs_auth
# Optional: path to a system Chromium (e.g. /usr/bin/chromium). Leave empty to
# use the Chromium that Puppeteer downloads with whatsapp-web.js.
PUPPETEER_EXECUTABLE_PATH=

# --- Admin bootstrap (used ONLY by `npm run db:seed`) ---
# Display name of the single Admin account created by the seed.
ADMIN_NAME=Administrator

# Email + password for the single Admin. Required to run the seed.
# Password must be at least 8 characters.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-please
